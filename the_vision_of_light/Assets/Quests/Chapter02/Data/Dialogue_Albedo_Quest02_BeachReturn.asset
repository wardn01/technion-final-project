  m_Script: {fileID: 11500000, guid: 6afaf71966ea65643a2583b7ff0771a3, type: 3}
  m_Name: Dialogue_Albedo_Quest02_BeachReturn
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  npcName: Albedo
  dialogueLines:
  - "Well done, Xiao. The beach is safer because of you."
  - "But you took wounds out there — don't be reckless."
  - "Visit the merchant in the village and buy a Health Potion."
  - "Stock up, then return to me."
