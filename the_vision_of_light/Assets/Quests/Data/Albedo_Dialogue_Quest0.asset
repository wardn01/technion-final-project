  m_Script: {fileID: 11500000, guid: 6afaf71966ea65643a2583b7ff0771a3, type: 3}
  m_Name: Albedo_Dialogue_Quest0
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  npcName: Albedo
  dialogueLines:
  - 'Xiao... Gods... you''re awake. You finally opened your eyes.

'
  - 'Easy now... easy. Don''t try to move too fast.

'
  - 'You made it through the nightmare... but the waking world isn''t much kinder.

'
  - 'I... I wish I had better news.

'
  - 'Your comrades fought with everything they had... truly, they did.

'
  - 'But they didn''t make it.

'
  - 'We laid them to rest... on the quiet hill, at the far end of the village.

'
  - 'It was peaceful there. As peaceful as we could make it.

'
  - 'And there''s more. The Shadow Entity... it took the Heartstone.

'
  - 'The darkness is already spreading. Taking root.

'
  - 'Go to the hill first. Say your goodbyes. Pay your respects.

'
  - 'When you''re ready... come back to me. There''s much we need to talk about.

'
