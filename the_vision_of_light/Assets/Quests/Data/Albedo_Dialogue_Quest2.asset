  m_Script: {fileID: 11500000, guid: 6afaf71966ea65643a2583b7ff0771a3, type: 3}
  m_Name: Albedo_Dialogue_Quest2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  npcName: Albedo
  dialogueLines:
  - Ah, you have returned. Thank you for honoring our fallen comrades.
  - While you were resting, I searched the grounds where the Shadow Entity attacked
    us.
  - I found this in the wreckage... your Wind Sword. You dropped it when you fell
    in battle.
  - Take it back, Xiao. You will need it immediately. Monsters have swarmed the beach,
    and we need your strength to clear them out!
