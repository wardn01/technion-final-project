  m_Script: {fileID: 11500000, guid: 6afaf71966ea65643a2583b7ff0771a3, type: 3}
  m_Name: Dialogue_Villager_Quest01_Return
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  npcName: Albedo
  dialogueLines:
  - "You went to the hill... I'm glad you didn't turn away from them."
  - "They believed in you, Xiao. They would want you to keep fighting — not to carry this alone."
  - "The forest took the monster, but it won't stay hidden forever. You'll need a real blade."
  - "Take your Wind Sword. It's yours now. May it guide you through what's coming."
