  m_Script: {fileID: 11500000, guid: 6afaf71966ea65643a2583b7ff0771a3, type: 3}
  m_Name: Albedo_Dialogue_Quest4
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  npcName: Albedo
  dialogueLines:
  - Incredible work! I saw the monsters scattering from here. You haven't lost your
    touch.
  - You saved our village today, but I fear your journey is just beginning.
  - Take this gold. Go visit the village Merchant and buy a Small Health Potion.
    You must be prepared for what's next.
