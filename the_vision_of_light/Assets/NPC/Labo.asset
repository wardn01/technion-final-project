  m_Script: {fileID: 11500000, guid: 6afaf71966ea65643a2583b7ff0771a3, type: 3}
  m_Name: Labo
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  npcName: Labo
  dialogueLines:
  - "\u0634\u064A\u0627\u0648! \u0627\u0644\u062D\u0645\u062F \u0644\u0644\u0647
    \u0623\u0646\u0643 \u0627\u0633\u062A\u064A\u0642\u0638\u062A \u0623\u062E\u064A\u0631\u0627\u064B...\""
  - "\u0648\u062D\u0634 '\u0643\u064A\u0627\u0646 \u0627\u0644\u0638\u0644' \u0647\u0627\u062C\u0645\u0646\u0627
    \u0628\u063A\u062A\u0629\u060C \u0644\u0642\u062F \u0642\u062A\u0644 \u0623\u0635\u062F\u0642\u0627\u0621\u0643
    \u0648\u0633\u0631\u0642 \u0627\u0644\u062D\u062C\u0631 \u0627\u0644\u0633\u062D\u0631\u064A!"
  - "\u0627\u0644\u0634\u062C\u0631\u0629 \u0627\u0644\u0639\u0638\u064A\u0645\u0629
    \u062A\u062D\u062A\u0636\u0631 \u0648\u062A\u062D\u0648\u0644\u062A \u0644\u0644\u0648\u0646
    \u0627\u0644\u0623\u0633\u0648\u062F... \u0644\u0642\u062F \u0647\u0631\u0628
    \u0627\u0644\u0648\u062D\u0634 \u0646\u062D\u0648 \u0627\u0644\u063A\u0627\u0628\u0629\u060C
    \u0623\u0631\u062C\u0648\u0643 \u0623\u0646\u0642\u0630\u0646\u0627!\""
